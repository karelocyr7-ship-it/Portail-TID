# Ne jamais mettre de valeur réelle dans ce fichier.
NODE_ENV=development
TZ=Africa/Abidjan
PORTAL_PUBLIC_URL=https://portail.tadgroupe.com
KEYCLOAK_PUBLIC_URL=https://portail.tadgroupe.com/auth
DATABASE_URL=postgresql://portal_user:CHANGE_ME@postgres:5432/portal
KEYCLOAK_DATABASE_URL=postgresql://keycloak_user:CHANGE_ME@postgres:5432/keycloak
N8N_DATABASE_URL=postgresql://n8n_user:CHANGE_ME@postgres:5432/n8n
KEYCLOAK_CLIENT_ID=tad-portal
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_ISSUER=https://portail.tadgroupe.com/auth/realms/tad-groupe
SESSION_SECRET=CHANGE_ME_WITH_32_OR_MORE_RANDOM_BYTES
N8N_ENCRYPTION_KEY=CHANGE_ME_WITH_32_OR_MORE_RANDOM_BYTES
